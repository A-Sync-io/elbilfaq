---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import TeaserCard from '../../components/TeaserCard.astro';
import { SITE } from '../../config';

const allFAQs = await getCollection('faq', ({ data }) => !data.draft);
const sortedFAQs = allFAQs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalFAQs = allFAQs.length;
const categories = [...new Set(allFAQs.map((faq) => faq.data.category))];
---

<Layout 
  showSidebar={false}
  seo={{
    title: `Senaste artiklarna - ${SITE.name}`,
    description: `Utforska vår samling av ${totalFAQs} artiklar och guider om bolån.`,
    type: 'website'
  }}
>
  <!-- Page Header -->
  <section class="bg-card border-b border-border py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-muted-foreground hover:text-foreground transition-colors">Hem</a>
        <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-primary font-semibold">Artiklar</span>
      </nav>
      
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <span class="text-sm font-bold uppercase tracking-wider text-primary mb-2 block">Läs mer</span>
          <h1 class="text-4xl md:text-5xl font-extrabold text-foreground tracking-tight">Senaste artiklarna</h1>
          <p class="text-muted-foreground text-lg mt-4">Utforska ${totalFAQs} guider och analyser om bolån och bostadsmarknaden</p>
        </div>
        
        <a 
          href="/search" 
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-md border border-border bg-background text-foreground hover:bg-muted transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Sök artiklar
        </a>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="border-b border-border bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-3 overflow-x-auto scrollbar-hide">
        <span class="text-sm font-medium text-muted-foreground flex-shrink-0">Filtrera:</span>
        
        <a 
          href="/faq" 
          class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-primary text-white"
        >
          Alla
        </a>
        
        {categories.map((category) => (
          <a 
            href={`/categories/${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium text-foreground bg-muted hover:bg-zinc-200 dark:hover:bg-zinc-800 transition-colors capitalize"
          >
            {category}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedFAQs.map((faq) => (
          <TeaserCard faq={faq} />
        ))}
      </div>
    </div>
  </section>
</Layout>