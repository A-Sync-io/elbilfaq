---
import Layout from '../layouts/Layout.astro';
import MortgageCalculator from '../components/MortgageCalculator';
import { SITE } from '../config';

const title = `Bolånekalkylator - ${SITE.name}`;
const description = 'Beräkna din månadskostnad för bolån. Se amorteringskrav, ränteavdrag och total kostnad baserat på aktuella regler.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Bolånekalkylator',
  description,
  url: `${SITE.url}/kalkylator`,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'SEK',
  },
};
---

<Layout
  showSidebar={false}
  seo={{
    title,
    description,
    type: 'website',
  }}
>
  <section class="bg-card border-b border-border py-16 md:py-20 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 -mt-8">
    <div class="max-w-4xl mx-auto">
      <nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-muted-foreground hover:text-foreground transition-colors">Hem</a>
        <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-primary font-semibold">Kalkylator</span>
      </nav>
      <span class="text-sm font-bold uppercase tracking-wider text-primary mb-2 block">Verktyg</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-foreground tracking-tight">Bolånekalkylator</h1>
      <p class="text-muted-foreground text-lg mt-4">Beräkna din månadskostnad, amorteringskrav och ränteavdrag.</p>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto">
      <MortgageCalculator client:load />

      <div class="mt-10 bg-[var(--muted)] border border-[var(--border)] rounded-lg p-5 flex gap-4 items-start">
        <svg class="w-6 h-6 shrink-0 text-[var(--primary)] mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-[var(--foreground)] mb-1">Om amorteringskravet</p>
          <p class="text-sm text-[var(--muted-foreground)]">
            Amorteringskravet bestäms av din belåningsgrad och skuldkvot.
            <a href="/article/amorteringskrav" class="text-[var(--primary)] hover:underline font-medium">
              Läs mer om hur amorteringskravet fungerar
            </a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
