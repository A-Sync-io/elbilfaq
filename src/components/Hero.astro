---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/faq/*.{jpg,jpeg,png,webp}');

interface Props {
  faq: CollectionEntry<'faq'>;
}

const { faq } = Astro.props;
const { title, category, description } = faq.data;

let imageModule: ImageMetadata | undefined;
if (faq.data.ogImage) {
  const key = faq.data.ogImage.replace(/^\/images\//, '/src/assets/images/');
  if (images[key]) {
    imageModule = (await images[key]()).default;
  }
}
---

<article class="relative mb-12 rounded-lg overflow-hidden bg-muted group">
  <a href={`/article/${faq.slug}`} class="block text-inherit no-underline">
    <div class="relative w-full aspect-video md:aspect-[21/9] overflow-hidden">
      {imageModule ? (
        <Image
          src={imageModule}
          alt={title}
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 768px) 100vw, (max-width: 1280px) 100vw, 1280px"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="eager"
          format="webp"
          quality={80}
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-muted to-border text-muted-foreground transition-transform duration-500 group-hover:scale-105">
          <svg class="w-16 h-16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
      )}

      <!-- Overlay Gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
      <span class="inline-block text-xs font-bold uppercase tracking-wider text-primary mb-2">
        {category}
      </span>
      <h1 class="text-2xl md:text-4xl font-extrabold text-white leading-tight mb-2 group-hover:underline">
        {title}
      </h1>
      <p class="text-base md:text-lg text-gray-200 line-clamp-2 md:line-clamp-3">
        {description}
      </p>
    </div>
  </a>
</article>
